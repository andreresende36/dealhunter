# =============================================================================
# DealHunter — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# Supabase (banco de dados principal em nuvem)
# Obter em: https://supabase.com/dashboard → Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Telegram
# Criar bot em: https://t.me/BotFather
# IDs dos grupos: obter com @userinfobot ou via API
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-xxxx
TELEGRAM_GROUP_IDS=-1001234567890,-1009876543210
TELEGRAM_ADMIN_CHAT_ID=-1001234567890  # Chat ID para alertas críticos (opcional, usa o primeiro grupo como fallback)
TELEGRAM_SEND_DELAY=1.5      # Delay em segundos entre mensagens (evitar flood)

# -----------------------------------------------------------------------------
# WhatsApp (Evolution API)
# Documentação: https://doc.evolution-api.com
# -----------------------------------------------------------------------------
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=sua-chave-api-evolution
WHATSAPP_INSTANCE_NAME=dealhunter
WHATSAPP_GROUP_IDS=120363xxxxxx@g.us,120363yyyyyy@g.us
WHATSAPP_SEND_DELAY=3.0     # Delay em segundos entre mensagens (evitar ban)
WHATSAPP_MAX_MSG_PER_MIN=10  # Máximo de mensagens por minuto

# -----------------------------------------------------------------------------
# Claude API (Anthropic) — IA para análise de ofertas
# Obter em: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=1024
CLAUDE_TEMPERATURE=0.2

# -----------------------------------------------------------------------------
# Shlink — Encurtador de links + rastreamento
# Documentação: https://shlink.io/documentation/api-docs
# -----------------------------------------------------------------------------
SHLINK_API_URL=https://seu-shlink.com
SHLINK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SHLINK_DOMAIN=seu-dominio.com

# -----------------------------------------------------------------------------
# Mercado Livre — Afiliados
# Cadastro: https://www.mercadolivre.com.br/afiliados
# -----------------------------------------------------------------------------
ML_AFFILIATE_ID=seu-id-afiliado
ML_AFFILIATE_TAG=sempreblack


# -----------------------------------------------------------------------------
# Scraper — Configurações de anti-bloqueio
# -----------------------------------------------------------------------------
SCRAPER_DELAY_MIN=2.0        # Delay mínimo entre requisições (segundos)
SCRAPER_DELAY_MAX=5.0        # Delay máximo entre requisições (segundos)
SCRAPER_PAGE_TIMEOUT=30000   # Timeout de carregamento de página (ms)
SCRAPER_HEADLESS=true        # true=sem interface gráfica
SCRAPER_MAX_RETRIES=3        # Tentativas por página em caso de falha
SCRAPER_MAX_PAGES=10         # Número máximo de páginas por fonte
SCRAPER_PROXY_URL=           # Opcional: http://user:pass@host:port

# -----------------------------------------------------------------------------
# Score Engine — Filtros de qualidade de oferta
# -----------------------------------------------------------------------------
SCORE_MIN_DISCOUNT_PCT=20.0  # Desconto mínimo para considerar a oferta (%)
SCORE_MIN_SCORE=60           # Pontuação mínima para publicar (0-100)
SCORE_MIN_RATING=4.0         # Avaliação mínima do produto (estrelas)
SCORE_MIN_REVIEWS=10         # Número mínimo de avaliações
# Pesos por critério (soma = 100 para manter escala de 0-100)
SCORE_WEIGHT_DISCOUNT=35.0
SCORE_WEIGHT_BADGE=20.0
SCORE_WEIGHT_RATING=20.0
SCORE_WEIGHT_REVIEWS=10.0
SCORE_WEIGHT_FREE_SHIPPING=10.0
SCORE_WEIGHT_TITLE_QUALITY=5.0

# -----------------------------------------------------------------------------
# n8n — Orquestração de workflows
# -----------------------------------------------------------------------------
N8N_WEBHOOK_URL=http://localhost:5678/webhook/dealhunter
N8N_API_KEY=sua-chave-api-n8n

# -----------------------------------------------------------------------------
# SQLite — Banco de dados local (fallback quando Supabase indisponível)
# -----------------------------------------------------------------------------
SQLITE_DB_PATH=./data/dealhunter.db

# -----------------------------------------------------------------------------
# OpenRouter — Classificação de produtos por LLM
# Obter em: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
