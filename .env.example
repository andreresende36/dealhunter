# =============================================================================
# DealHunter — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# Supabase (banco de dados principal em nuvem)
# Obter em: https://supabase.com/dashboard → Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=images   # Bucket para imagens lifestyle geradas por IA

# -----------------------------------------------------------------------------
# Telegram — Bot de Ofertas
# Criar bots em: https://t.me/BotFather
# IDs dos grupos/canais: obter com @userinfobot ou via API getUpdates
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-xxxx
TELEGRAM_GROUP_IDS=-1001234567890,-1009876543210
TELEGRAM_SEND_DELAY=1.5      # Delay em segundos entre mensagens (evitar flood)

# Telegram — Bot de Alertas (monitoramento interno)
# Chat ID para alertas críticos (opcional, usa o primeiro grupo como fallback)
TELEGRAM_ALERT_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-yyyy
TELEGRAM_ADMIN_CHAT_ID=-1001234567890

# -----------------------------------------------------------------------------
# WhatsApp (Evolution API)
# Documentação: https://doc.evolution-api.com
# -----------------------------------------------------------------------------
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=sua-chave-api-evolution
WHATSAPP_INSTANCE_NAME=dealhunter
WHATSAPP_GROUP_IDS=120363xxxxxx@g.us,120363yyyyyy@g.us
WHATSAPP_SEND_DELAY=3.0      # Delay em segundos entre mensagens (evitar ban)
WHATSAPP_MAX_MSG_PER_MIN=10  # Máximo de mensagens por minuto

# -----------------------------------------------------------------------------
# Mercado Livre — Afiliados
# Cadastro: https://www.mercadolivre.com.br/afiliados
# -----------------------------------------------------------------------------
ML_AFFILIATE_TAG=sempreblack
# Cookies de sessão do ML (exportar do navegador, formato: "key=value; key2=value2")
# Necessários: _csrf, ssid, nsa_rotok, orguseridp, orgnickp
# O JWT (nsa_rotok) expira em ~30 dias — renove quando o AlertBot avisar.
ML_SESSION_COOKIES=
# CSRF token (header x-csrf-token do painel de afiliados)
ML_CSRF_TOKEN=
# Credenciais do usuário DealHunter (hash bcrypt gerado automaticamente ao criar o user)
ML_USER_NAME=Seu Nome
ML_USER_EMAIL=seu@email.com
ML_USER_PASSWORD=sua-senha-aqui

# -----------------------------------------------------------------------------
# Scraper — Configurações de anti-bloqueio e ciclo de execução
# -----------------------------------------------------------------------------
SCRAPER_DELAY_MIN=2.0        # Delay mínimo entre requisições (segundos)
SCRAPER_DELAY_MAX=5.0        # Delay máximo entre requisições (segundos)
SCRAPER_PAGE_TIMEOUT=30000   # Timeout de carregamento de página (ms)
SCRAPER_HEADLESS=true        # true=sem interface gráfica
SCRAPER_MAX_RETRIES=3        # Tentativas por página em caso de falha
SCRAPER_MAX_PAGES=10         # Número máximo de páginas por fonte
SCRAPER_PROXY_URL=           # Opcional: http://user:pass@host:port
SCRAPER_DEBUG_SCREENSHOTS=false  # true=salva HTML com screenshots dos cards rejeitados em debug/rejected/
SCRAPER_INTERVAL=3600        # Intervalo entre ciclos de scraping (segundos)

# -----------------------------------------------------------------------------
# Score Engine v2 — Filtros de qualidade de oferta
# Redistribuicao dinamica: quando um criterio nao tem dados (ex: rating=0),
# seu peso e redistribuido proporcionalmente entre os criterios com dados.
# -----------------------------------------------------------------------------
SCORE_MIN_DISCOUNT_PCT=20.0  # Desconto minimo para considerar a oferta (%)
SCORE_MIN_SCORE=60           # Pontuacao minima para publicar (0-100)
SCORE_MIN_RATING=4.0         # Avaliacao minima do produto (estrelas)
SCORE_MIN_REVIEWS=10         # Numero minimo de avaliacoes
# Pesos por criterio (soma = 100 para manter escala de 0-100)
SCORE_WEIGHT_DISCOUNT=30.0       # Curva sigmoid (centrada em 35%, cap 80%)
SCORE_WEIGHT_BADGE=15.0          # Discreto (oferta relampago > imperdivel > do dia > mais vendido)
SCORE_WEIGHT_RATING=15.0         # Linear (piso 3.5, teto 5.0)
SCORE_WEIGHT_REVIEWS=10.0        # Logaritmico (satura em 5000 reviews)
SCORE_WEIGHT_FREE_SHIPPING=10.0  # Binario (tem ou nao)
SCORE_WEIGHT_INSTALLMENTS=10.0   # Binario — parcelamento sem juros
SCORE_WEIGHT_TITLE_QUALITY=10.0  # Heuristicas (comprimento, marca, caps, spam, specs)

# -----------------------------------------------------------------------------
# Sender — Fila de envio com prioridade por score
# -----------------------------------------------------------------------------
SENDER_START_HOUR=8          # Hora de início do envio (BRT, 0-23)
SENDER_END_HOUR=23           # Hora de fim do envio (BRT, 0-23)
SENDER_MIN_INTERVAL=3        # Intervalo mínimo entre envios (minutos)
SENDER_MAX_INTERVAL=6        # Intervalo máximo entre envios (minutos)
SENDER_TIMEZONE=America/Sao_Paulo
# Método de imagem: "layered" (busca em camadas: marca → ML API → thumbnail)
#                   "lifestyle" (geração IA: Haiku + modelo de imagem)
IMAGE_METHOD=layered
LIFESTYLE_MAX_RETRIES=2      # Retries para geração de imagem lifestyle via IA
# Modelo de imagem lifestyle — use o alias OU o model ID direto do OpenRouter:
#   flux-flex                  → black-forest-labs/flux.2-flex
#   flux-klein                → black-forest-labs/flux.2-klein-4b
#   flux-max                  → black-forest-labs/flux.2-max
#   flux-pro                  → black-forest-labs/flux.2-pro
#   nano-banana (default)    → google/gemini-2.5-flash-image
#   nano-banana-2            → google/gemini-3.1-flash-image-preview
#   nano-banana-pro          → google/gemini-3-pro-image-preview
#   gpt5-image               → openai/gpt-5-image
#   gpt5-image-mini          → openai/gpt-5-image-mini
#   riverflow-fast            → sourceful/riverflow-v2-fast
#   riverflow-fast-preview    → sourceful/riverflow-v2-fast-preview
#   riverflow-max-preview     → sourceful/riverflow-v2-max-preview
#   riverflow-pro             → sourceful/riverflow-v2-pro
#   riverflow-std-preview     → sourceful/riverflow-v2-standard-preview
#   seedream                 → bytedance-seed/seedream-4.5
LIFESTYLE_IMAGE_MODEL=nano-banana-2

# -----------------------------------------------------------------------------
# SQLite — Banco de dados local (fallback quando Supabase indisponível)
# -----------------------------------------------------------------------------
SQLITE_DB_PATH=./data/dealhunter.db

# -----------------------------------------------------------------------------
# OpenRouter — LLM para classificação de produtos e geração de imagens lifestyle
# Obter em: https://openrouter.ai/keys
# Modelos utilizados: Claude Haiku (análise) + Gemini 2.5 Flash (geração de imagem)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
